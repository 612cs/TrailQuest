        </mxCell>
        <mxCell id="n1" value="用户进入推荐页&#xa;设置地区 / 难度 / 行程偏好" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#222222;fillColor=#ffffff;fontSize=14;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="620" y="180" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n2" value="系统读取用户画像&#xa;与历史行为数据" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#222222;fillColor=#ffffff;fontSize=14;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="620" y="290" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n3" value="筛选候选路线&#xa;匹配地理位置与基础条件" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#222222;fillColor=#ffffff;fontSize=14;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="620" y="400" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n4" value="融合推荐特征&#xa;偏好匹配度 / 热度 / 评分 / 景观信息" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;strokeColor=#222222;fillColor=#ffffff;fontSize=14;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="620" y="510" width="280" height="80" as="geometry" />
