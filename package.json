{
  "name": "trailquest-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --dir apps/web dev",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "./dev-api.sh",
    "dev:admin": "pnpm --dir apps/admin dev",
    "build": "pnpm --dir apps/web build",
    "build:web": "pnpm --dir apps/web build",
    "build:admin": "pnpm --dir apps/admin build",
    "build:api": "./apps/api/mvnw -f apps/api/pom.xml clean package -DskipTests",
    "typecheck": "pnpm typecheck:web && pnpm typecheck:admin",
    "typecheck:web": "pnpm --dir apps/web exec vue-tsc -b --noEmit",
    "typecheck:admin": "pnpm --dir apps/admin exec vue-tsc -b --noEmit",
    "lint": "oxlint apps/web apps/admin packages/ui tools/harness",
    "lint:fix": "oxlint --fix apps/web apps/admin packages/ui tools/harness",
    "format": "oxfmt package.json apps/web apps/admin packages/ui tools/harness",
    "format:check": "oxfmt --check package.json apps/web apps/admin packages/ui tools/harness",
    "preview": "pnpm --dir apps/web preview",
    "preview:web": "pnpm --dir apps/web preview",
    "preview:admin": "pnpm --dir apps/admin preview",
    "harness:check": "node tools/harness/index.mjs",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm harness:check && pnpm test:web:unit",
    "test": "pnpm test:web:unit && pnpm test:api",
    "test:api": "./apps/api/mvnw -f apps/api/pom.xml test",
    "test:web:unit": "pnpm --dir apps/web test:unit",
    "test:web:e2e": "pnpm --dir apps/web test:e2e"
  },
  "devDependencies": {
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0"
  }
}
