{
  "name": "trailquest-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm --dir apps/web dev",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "./apps/api/mvnw -f apps/api/pom.xml spring-boot:run",
    "build": "pnpm --dir apps/web build",
    "build:web": "pnpm --dir apps/web build",
    "build:api": "./apps/api/mvnw -f apps/api/pom.xml clean package -DskipTests",
    "preview": "pnpm --dir apps/web preview",
    "preview:web": "pnpm --dir apps/web preview",
    "test:api": "./apps/api/mvnw -f apps/api/pom.xml test"
  }
}
